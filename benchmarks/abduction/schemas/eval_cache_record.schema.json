{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SerafimBatzoglou/concept-synth/benchmarks/abduction/schemas/eval_cache_record.schema.json",
  "title": "ABD Eval Cache Record",
  "type": "object",
  "required": [
    "schema_version",
    "dataset_name",
    "dataset_path",
    "dataset_sha256",
    "holdout_sha256",
    "instance_id",
    "scenario",
    "theory",
    "model_id",
    "run_id",
    "prediction",
    "train_eval",
    "holdout_eval"
  ],
  "properties": {
    "schema_version": {
      "const": "abd_eval_v1"
    },
    "dataset_name": {
      "type": "string",
      "minLength": 1
    },
    "dataset_path": {
      "type": "string",
      "minLength": 1
    },
    "dataset_sha256": {
      "type": "string",
      "minLength": 1
    },
    "holdout_sha256": {
      "type": "string",
      "minLength": 1
    },
    "instance_id": {
      "type": "string",
      "minLength": 1
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "theory": {
      "type": "string",
      "minLength": 1
    },
    "model_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "prediction": {
      "type": "object"
    },
    "train_eval": {
      "type": "object"
    },
    "holdout_eval": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
