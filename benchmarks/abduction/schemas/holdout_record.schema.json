{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SerafimBatzoglou/concept-synth/benchmarks/abduction/schemas/holdout_record.schema.json",
  "title": "ABD Holdout Record",
  "type": "object",
  "required": ["schemaVersion", "instanceId", "scenario", "theoryId", "holdoutIdx", "world"],
  "properties": {
    "schemaVersion": {
      "const": "abd_holdout_record_v1"
    },
    "instanceId": {
      "type": "string",
      "minLength": 1
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "theoryId": {
      "type": "string",
      "minLength": 1
    },
    "holdoutIdx": {
      "type": "integer",
      "minimum": 0
    },
    "world": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
